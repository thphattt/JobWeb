# ── Site URL (SEO: canonical, OpenGraph, sitemap, robots) ──────────────
# Đặt domain thật khi deploy để canonical/OG/sitemap ra đúng URL tuyệt đối.
# Trên Vercel có thể để trống — hệ thống tự dùng VERCEL_URL.
# Local để trống → fallback http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://tanchauthanh.com

# ── Email (Resend) ─────────────────────────────────────────────────────
# RESEND_API_KEY dùng cho CẢ HAI: (1) form liên hệ, (2) email hệ thống của
# Payload (khôi phục mật khẩu admin…). Chưa có key thì form vẫn chạy
# (validate + báo thành công + log server); email hệ thống chỉ log ra console.
# Lấy API key tại https://resend.com.
RESEND_API_KEY=
# Nơi NHẬN email từ form liên hệ.
CONTACT_TO_EMAIL=tanchauthanhhn@gmail.com
# Người GỬI form liên hệ (kèm tên hiển thị).
CONTACT_FROM_EMAIL="Tân Châu Thành <onboarding@resend.dev>"
# Người GỬI email hệ thống Payload (chỉ địa chỉ, không kèm tên). Tuỳ chọn —
# để trống sẽ dùng onboarding@resend.dev. Khi có domain riêng đã xác thực
# trong Resend, đổi thành vd no-reply@tanchauthanh.com.
# CONTACT_FROM_ADDRESS=no-reply@tanchauthanh.com

# ── CMS (Payload 3 + Postgres) ─────────────────────────────────────────
# Bắt buộc để chạy /admin. DATABASE_URI: connection string Postgres (vd Neon).
# PAYLOAD_SECRET: chuỗi ngẫu nhiên ≥ 32 ký tự, tạo bằng:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATABASE_URI=
PAYLOAD_SECRET=